OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free
WHISPER_MODEL=tiny
API_HOST=0.0.0.0
API_PORT=8010
PORT=8010

# For local development with Vite frontend on port 5173:
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# For production (Vercel frontend), use:
# CORS_ALLOW_ORIGINS=https://your-vercel-domain.vercel.app

# For multiple origins (comma-separated):
# CORS_ALLOW_ORIGINS=http://localhost:5173,https://your-vercel-domain.vercel.app
